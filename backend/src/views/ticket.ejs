<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body{font-family: Arial, Helvetica, sans-serif; margin:20px; color:#222}
    .ticket{border:1px solid #e2e8f0; padding:20px; max-width:720px; margin:0 auto; box-shadow:0 6px 18px rgba(15,23,42,0.06)}
    .header{display:flex;justify-content:space-between;align-items:center}
    .title{font-size:20px;font-weight:700}
    .meta{color:#374151;font-size:14px}
    .section{margin-top:14px}
    .qr{margin-top:12px}
    .footer{margin-top:18px;color:#6b7280;font-size:13px}
  </style>
</head>
<body>
  <div class="ticket">
    <div class="header">
      <div>
        <div class="title"><%= event?.title || 'Event Ticket' %></div>
        <div class="meta"><%= event?.date ? new Date(event.date).toLocaleDateString('en-PK') : '' %> • <%= event?.location || '' %></div>
      </div>
    </div>

    <div class="section">
      <strong>Event Category</strong>
      <div><%= event?.category || 'General' %></div>
    </div>

    <div class="section">
      <strong>Ticket Holder</strong>
      <div><%= ticket?.purchaserName || 'Guest' %></div>
    </div>

    <div class="section">
      <strong>Contact</strong>
      <div><%= ticket?.purchaserEmail || '' %></div>
    </div>

    <div class="section">
      <strong>Quantity</strong>
      <div><%= ticket?.quantity || 1 %> ticket(s)</div>
    </div>

    <div class="section">
      <strong>Total Amount</strong>
      <div>PKR <%= ticket?.totalAmount || 0 %></div>
    </div>

    <% if (qrDataUrl) { %>
      <div class="qr">
        <img src="<%= qrDataUrl %>" alt="QR code" width="140" />
      </div>
    <% } %>

    <div class="footer">
      <div>Present this ticket at the event entrance. This PDF was generated by Event Management System.</div>
      <div style="margin-top:10px; font-size:11px;">Generated on <%= new Date().toLocaleString('en-PK') %></div>
    </div>
  </div>
</body>
</html>
